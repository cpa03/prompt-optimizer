{
  "version": 1,
  "include": ["/*"],
  "exclude": [
    "/assets/*",
    "/*.js",
    "/*.mjs",
    "/*.css",
    "/*.html",
    "/*.json",
    "/*.xml",
    "/*.txt",
    "/*.ico",
    "/*.png",
    "/*.jpg",
    "/*.jpeg",
    "/*.gif",
    "/*.svg",
    "/*.webp",
    "/*.avif",
    "/*.woff",
    "/*.woff2",
    "/*.ttf",
    "/*.eot",
    "/*.otf",
    "/*.map",
    "/*.webmanifest",
    "/favicon.ico",
    "/robots.txt",
    "/config.js",
    "/.well-known/*"
  ]
