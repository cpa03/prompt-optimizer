{
  "name": "prompt-optimizer",
  "version": "2.5.3",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": "^18.0.0 || ^20.0.0 || ^22.0.0",
    "npm": "请使用pnpm代替npm",
    "yarn": "请使用pnpm代替yarn"
  },
  "scripts": {
    "build": "npm-run-all build:mcp build:core build:ui build:parallel",
    "build:core": "pnpm -F @prompt-optimizer/core build",
    "build:ui": "pnpm -F @prompt-optimizer/ui build",
    "build:parallel": "npm-run-all --parallel build:web build:ext",
    "build:web": "pnpm -F @prompt-optimizer/web build",
    "build:ext": "pnpm -F @prompt-optimizer/extension build",
    "build:desktop-only": "pnpm -F @prompt-optimizer/desktop build",
    "build:desktop": "npm-run-all build:mcp build:core build:ui build:web build:desktop-only",
    "build:mcp": "pnpm -F @prompt-optimizer/mcp-server build",
    "dev": "npm-run-all clean:dist build:core build:ui dev:parallel",
    "dev:fresh": "npm-run-all kill:dev clean pnpm-install dev",
    "dev:parallel": "concurrently -k -p \"[{name}]\" -n \"UI,WEB\" \"pnpm -F @prompt-optimizer/ui build --watch\" \"pnpm -F @prompt-optimizer/web dev\"",
    "dev:ext": "pnpm -F @prompt-optimizer/extension dev",
    "dev:desktop": "npm-run-all clean:dist build:core build:ui dev:desktop:parallel",
    "dev:desktop:fresh": "npm-run-all kill:dev clean pnpm-install dev:desktop",
    "dev:desktop:parallel": "concurrently -k -p \"[{name}]\" -n \"WEB,DESKTOP\" \"pnpm -F @prompt-optimizer/web dev\" \"pnpm -F @prompt-optimizer/desktop dev\"",
    "test": "npm-run-all -s test:unit test:e2e:smart",
    "test:unit": "pnpm -F @prompt-optimizer/core build && pnpm -r test --run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:smart": "node scripts/smart-e2e.js",
    "test:e2e:record": "cross-env E2E_VCR_MODE=record playwright test",
    "test:e2e:replay": "cross-env E2E_VCR_MODE=replay playwright test",
    "test:gate:core": "pnpm -F @prompt-optimizer/core test:gate",
    "test:gate:ui": "pnpm -F @prompt-optimizer/core build && pnpm -F @prompt-optimizer/ui test",
    "test:gate:e2e": "playwright test tests/e2e/regression.spec.ts tests/e2e/workflows/p0-route-smoke.spec.ts",
    "test:gate": "npm-run-all -s test:gate:core test:gate:ui",
    "test:gate:coverage": "pnpm -F @prompt-optimizer/core test:gate:coverage",
    "test:gate:full": "npm-run-all -s test:gate test:gate:e2e",
    "test:fast": "pnpm -F @prompt-optimizer/core build && pnpm -r test --run --passWithNoTests",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "clean": "npm-run-all clean:dist clean:vite",
    "clean:dist": "rimraf packages/core/dist packages/ui/dist packages/web/dist packages/extension/dist packages/desktop/dist packages/desktop/web-dist",
    "clean:vite": "rimraf packages/core/node_modules/.vite packages/ui/node_modules/.vite packages/web/node_modules/.vite packages/extension/node_modules/.vite",
    "pnpm-install": "pnpm install",
    "version:sync": "node scripts/sync-versions.js",
    "version": "pnpm run version:sync && git add -A",
    "version:prepare": "pnpm version --no-git-tag-version",
    "version:tag": "git tag v$(node -p \"require('./package.json').version\")",
    "version:publish": "git push origin v$(node -p \"require('./package.json').version\")",
    "mcp:build": "pnpm --filter @prompt-optimizer/mcp-server build",
    "mcp:dev": "pnpm --filter @prompt-optimizer/mcp-server dev",
    "mcp:start": "pnpm --filter @prompt-optimizer/mcp-server start",
    "mcp:test": "pnpm --filter @prompt-optimizer/mcp-server test",
    "lint": "npm-run-all lint:core lint:ui lint:mcp lint:web lint:ext",
    "lint:core": "pnpm -F @prompt-optimizer/core lint",
    "lint:ui": "pnpm -F @prompt-optimizer/ui lint",
    "lint:mcp": "pnpm -F @prompt-optimizer/mcp-server lint",
    "lint:web": "pnpm -F @prompt-optimizer/web lint",
    "lint:ext": "pnpm -F @prompt-optimizer/extension lint",
    "lint:fix": "npm-run-all lint:fix:core lint:fix:ui lint:fix:mcp lint:fix:web lint:fix:ext",
    "lint:fix:core": "pnpm -F @prompt-optimizer/core lint:fix",
    "lint:fix:ui": "pnpm -F @prompt-optimizer/ui lint:fix",
    "lint:fix:mcp": "pnpm -F @prompt-optimizer/mcp-server lint:fix",
    "lint:fix:web": "pnpm -F @prompt-optimizer/web lint:fix",
    "lint:fix:ext": "pnpm -F @prompt-optimizer/extension lint:fix",
    "type-check": "npm-run-all build:core type-check:all",
    "type-check:all": "npm-run-all --parallel type-check:core type-check:ui type-check:mcp",
    "type-check:core": "tsc --noEmit -p packages/core/tsconfig.json",
    "type-check:ui": "pnpm -F @prompt-optimizer/ui typecheck",
    "type-check:mcp": "pnpm -F @prompt-optimizer/mcp-server type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bmad:refresh": "bmad-method install -f -i codex",
    "bmad:list": "bmad-method list:agents",
    "bmad:validate": "bmad-method validate",
    "kill:dev": "node scripts/kill-dev.js",
    "brocula": "node scripts/brocula-master.js",
    "brocula:once": "node scripts/brocula-master.js --once",
    "brocula:console": "node scripts/brocula-console-monitor.js",
    "brocula:lighthouse": "node scripts/brocula-lighthouse.js",
    "brocula:health": "node scripts/brocula-health-check.js",
    "story:validate": "node scripts/validate-story.js",
    "story:validate:all": "node scripts/validate-story.js --all",
    "story:create": "node scripts/create-story.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260228.0",
    "npm-run-all": "^4.1.5"
  }
}
