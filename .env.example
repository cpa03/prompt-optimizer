# =============================================================================
# Prompt Optimizer Environment Configuration
# =============================================================================
# 
# ⚠️  SECURITY WARNING ⚠️
# 
# This file contains sensitive API keys and configuration. Follow these best practices:
# 
# 1. NEVER commit .env files to version control (already in .gitignore)
# 2. Use different API keys for development/staging/production
# 3. Rotate API keys regularly (every 90 days recommended)
# 4. Use minimal permissions for each API key
# 5. Monitor API usage on provider dashboards
# 6. In production, use secure environment variable injection
# 7. Never share API keys via email, chat, or code commits
# 
# Copy this file to .env and customize as needed.
# =============================================================================

# Flexy loves modularity! All hardcoded values are now configurable.
# Copy this file to .env and customize as needed.

# =============================================================================
# PORT CONFIGURATION
# =============================================================================

# Web development server port (default: 18181)
VITE_WEB_PORT=18181

# E2E test server port (default: 15555)
E2E_PORT=15555

# MCP HTTP server port (default: 3000)
MCP_HTTP_PORT=3000

# =============================================================================
# TIMEOUT CONFIGURATION
# =============================================================================

# Default timeout in milliseconds (default: 30000)
VITE_TIMEOUT_DEFAULT=30000

# Short timeout for quick operations (default: 5000)
VITE_TIMEOUT_SHORT=5000

# Medium timeout for standard operations (default: 10000)
VITE_TIMEOUT_MEDIUM=10000

# Long timeout for heavy operations (default: 60000)
VITE_TIMEOUT_LONG=60000

# LLM service timeout (default: 60000)
VITE_LLM_TIMEOUT=60000

# Image generation timeout (default: 120000)
VITE_IMAGE_TIMEOUT=120000

# Save operation timeout (default: 5000)
VITE_SAVE_TIMEOUT=5000

# Emergency exit timeout (default: 10000)
VITE_EMERGENCY_EXIT_TIMEOUT=10000

# Electron initialization timeout (default: 5000)
VITE_ELECTRON_INIT_TIMEOUT=5000

# Retry configuration
VITE_RETRY_MAX_ATTEMPTS=5
VITE_RETRY_DELAY=1000
VITE_RETRY_MAX_DELAY=10000

# =============================================================================
# SIZE LIMITS
# =============================================================================

# Maximum image size in bytes (default: 10485760 = 10MB)
VITE_MAX_IMAGE_SIZE_BYTES=10485760

# Maximum image cache size in bytes (default: 52428800 = 50MB)
VITE_MAX_IMAGE_CACHE_BYTES=52428800

# Maximum image dimension (default: 4096)
VITE_MAX_IMAGE_DIMENSION=4096

# MCP max prompt length (default: 50000)
VITE_MCP_MAX_PROMPT_LENGTH=50000

# MCP max requirements length (default: 10000)
VITE_MCP_MAX_REQUIREMENTS_LENGTH=10000

# Max retries (default: 5)
VITE_MAX_RETRIES=5

# =============================================================================
# LLM DEFAULT PARAMETERS
# =============================================================================

# Default temperature (default: 0.7)
VITE_LLM_TEMPERATURE=0.7

# Default max tokens (default: 4096)
VITE_LLM_MAX_TOKENS=4096

# Default top_p (default: 1.0)
VITE_LLM_TOP_P=1.0

# Default frequency penalty (default: 0)
VITE_LLM_FREQ_PENALTY=0

# Default presence penalty (default: 0)
VITE_LLM_PRESENCE_PENALTY=0

# =============================================================================
# PROVIDER URLS - Override for enterprise proxies or custom endpoints
# =============================================================================

# OpenAI
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
# VITE_OPENAI_API_KEY=your_key_here

# Anthropic
VITE_ANTHROPIC_BASE_URL=https://api.anthropic.com
# VITE_ANTHROPIC_API_KEY=your_key_here

# Ollama (default: localhost, override for remote instances)
VITE_OLLAMA_BASE_URL=http://localhost:11434/v1
VITE_OLLAMA_DEFAULT_MODEL=llama2
# VITE_OLLAMA_API_KEY=your_key_here

# DeepSeek
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# VITE_DEEPSEEK_API_KEY=your_key_here

# SiliconFlow
VITE_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# VITE_SILICONFLOW_API_KEY=your_key_here

# OpenRouter
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# VITE_OPENROUTER_API_KEY=your_key_here

# Gemini
VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# VITE_GEMINI_API_KEY=your_key_here

# DashScope (Alibaba)
VITE_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# VITE_DASHSCOPE_API_KEY=your_key_here

# ModelScope
VITE_MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
# VITE_MODELSCOPE_API_KEY=your_key_here

# SeaDream
VITE_SEEDREAM_BASE_URL=https://api.seaart.ai/v1
# VITE_SEEDREAM_API_KEY=your_key_here

# Zhipu
VITE_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# VITE_ZHIPU_API_KEY=your_key_here

# =============================================================================
# IMAGE SIZE PRESETS
# =============================================================================

# Standard image sizes
VITE_IMAGE_SIZE_DEFAULT=1024x1024
VITE_IMAGE_SIZE_OPTIONS=1024x1024,1536x1024,1024x1536,auto

# OpenAI-specific
VITE_OPENAI_IMAGE_SIZE_DEFAULT=1024x1024
VITE_OPENAI_IMAGE_SIZE_OPTIONS=1024x1024,1536x1024,1024x1536,auto

# SiliconFlow-specific
VITE_SILICONFLOW_IMAGE_SIZE_DEFAULT=1024x1024
VITE_SILICONFLOW_IMAGE_SIZE_OPTIONS=1024x1024,960x1280,768x1024,1280x960,1024x768,1280x1280

# SeaDream-specific
VITE_SEEDREAM_SIZE_DEFAULT=2K
VITE_SEEDREAM_SIZE_OPTIONS=1K,2K,4K,1024x1024,512x512,768x768

# ModelScope-specific
VITE_MODELSCOPE_IMAGE_SIZE_DEFAULT=1024x1024
VITE_MODELSCOPE_IMAGE_SIZE_OPTIONS=1024x1024,1536x1024,1024x1536

# =============================================================================
# IMAGE GENERATION DEFAULTS
# =============================================================================

# SeaDream defaults
VITE_SEEDREAM_ASPECT_RATIO=2K
VITE_SEEDREAM_SEED=-1
VITE_SEEDREAM_SAMPLE_METHOD=default
VITE_SEEDREAM_CFG=7.5
VITE_SEEDREAM_STEPS=20

# SiliconFlow defaults
VITE_SILICONFLOW_STEPS=20
VITE_SILICONFLOW_GUIDANCE_SCALE=7.5
VITE_SILICONFLOW_INFERENCE_STEPS=50
VITE_SILICONFLOW_STRENGTH=4.0

# OpenAI defaults
VITE_OPENAI_IMAGE_QUALITY=standard
VITE_OPENAI_IMAGE_FORMAT=url
VITE_OPENAI_IMAGE_STYLE=vivid

# =============================================================================
# STORAGE KEYS - Override if you need to namespace your installation
# =============================================================================

VITE_STORAGE_KEY_VARIABLES=variable-manager-data
VITE_STORAGE_KEY_SETTINGS=global-settings/v1
VITE_STORAGE_KEY_CHUNK_PROMPT=prompt-optimizer:chunk-load-refresh-prompted
VITE_STORAGE_KEY_IMG_T2I=image:text2image:session
VITE_STORAGE_KEY_IMG_I2I=image:image2image:session

# =============================================================================
# EXTERNAL URLS
# =============================================================================

VITE_GITHUB_REPO_URL=https://github.com/linshenkx/prompt-optimizer

# =============================================================================
# MODEL DEFAULTS
# =============================================================================

VITE_CUSTOM_MODEL_ID=custom-model
VITE_FALLBACK_API_KEY=ollama

# =============================================================================
# VERSION
# =============================================================================

VITE_SETTINGS_VERSION=v1

# =============================================================================
# TEST PROMPTS - Flexy loves modularity! Customize test prompts per provider
# =============================================================================

# Default test prompts for text-to-image generation
VITE_TEST_PROMPT_TEXT2IMAGE_DEFAULT=a simple red flower
VITE_TEST_PROMPT_TEXT2IMAGE_OPENAI=a simple red flower
VITE_TEST_PROMPT_TEXT2IMAGE_SILICONFLOW=a flower
VITE_TEST_PROMPT_TEXT2IMAGE_GEMINI=a simple red flower
VITE_TEST_PROMPT_TEXT2IMAGE_DASHSCOPE=一朵简单的红色花朵
VITE_TEST_PROMPT_TEXT2IMAGE_MODELSCOPE=a simple red flower
VITE_TEST_PROMPT_TEXT2IMAGE_SEEDREAM=a beautiful landscape with mountains and lake
VITE_TEST_PROMPT_TEXT2IMAGE_OLLAMA=a simple red flower
VITE_TEST_PROMPT_TEXT2IMAGE_OPENROUTER=a simple red flower

# Default test prompts for image-to-image generation
VITE_TEST_PROMPT_IMAGE2IMAGE_DEFAULT=make this image more colorful
VITE_TEST_PROMPT_IMAGE2IMAGE_OPENAI=make this image more colorful
VITE_TEST_PROMPT_IMAGE2IMAGE_SILICONFLOW=make it red
VITE_TEST_PROMPT_IMAGE2IMAGE_GEMINI=make this image more colorful
VITE_TEST_PROMPT_IMAGE2IMAGE_MODELSCOPE=make this image more colorful
VITE_TEST_PROMPT_IMAGE2IMAGE_SEEDREAM=enhance the colors and add more details
VITE_TEST_PROMPT_IMAGE2IMAGE_OLLAMA=make this image more colorful
VITE_TEST_PROMPT_IMAGE2IMAGE_OPENROUTER=make this image more colorful

# =============================================================================
# PROVIDER API KEY URLS - Override for enterprise/white-label deployments
# =============================================================================

# VITE_OPENAI_API_KEY_URL=https://platform.openai.com/api-keys
# VITE_GEMINI_API_KEY_URL=https://aistudio.google.com/apikey
# VITE_SILICONFLOW_API_KEY_URL=https://cloud.siliconflow.cn/account/ak
# VITE_DASHSCOPE_API_KEY_URL=https://bailian.console.aliyun.com/#/api-key
# VITE_MODELSCOPE_API_KEY_URL=https://modelscope.cn/my/apiKey
# VITE_SEEDREAM_API_KEY_URL=https://www.seaart.ai/workroom
# VITE_OPENROUTER_API_KEY_URL=https://openrouter.ai/keys
# VITE_ANTHROPIC_API_KEY_URL=https://console.anthropic.com/settings/keys
# VITE_DEEPSEEK_API_KEY_URL=https://platform.deepseek.com/api_keys
# VITE_ZHIPU_API_KEY_URL=https://open.bigmodel.cn/usercenter/apikeys

# =============================================================================
# OPENAI IMAGE PARAMETERS
# =============================================================================

# Quality options (comma-separated)
VITE_OPENAI_QUALITY_OPTIONS=auto,high,medium,low
VITE_OPENAI_QUALITY_DEFAULT=auto

# Background options (comma-separated)
VITE_OPENAI_BACKGROUND_OPTIONS=auto,transparent,opaque
VITE_OPENAI_BACKGROUND_DEFAULT=auto

# =============================================================================
# SILICONFLOW IMAGE PARAMETERS
# =============================================================================

# Guidance scale configuration
VITE_SILICONFLOW_GUIDANCE_MIN=1.0
VITE_SILICONFLOW_GUIDANCE_MAX=20.0
VITE_SILICONFLOW_GUIDANCE_STEP=0.5

# Steps configuration
VITE_SILICONFLOW_STEPS_MIN=1
VITE_SILICONFLOW_STEPS_MAX=100

# Qwen-Image specific sizes (comma-separated)
VITE_SILICONFLOW_QWEN_SIZES=1328x1328,1664x928,928x1664,1472x1140,1140x1472,1584x1056,1056x1584
VITE_SILICONFLOW_QWEN_SIZE_DEFAULT=1328x1328

# Qwen-Image CFG scale
VITE_SILICONFLOW_QWEN_CFG_MIN=0.1
VITE_SILICONFLOW_QWEN_CFG_MAX=20.0
VITE_SILICONFLOW_QWEN_CFG_STEP=0.1

# =============================================================================
# DASHSCOPE (ALIYUN) IMAGE PARAMETERS
# =============================================================================

# Image sizes (comma-separated)
VITE_DASHSCOPE_SIZES=1664*928,1472*1140,1328*1328,1140*1472,928*1664
VITE_DASHSCOPE_SIZE_DEFAULT=1328*1328

# Default parameter values
VITE_DASHSCOPE_PROMPT_EXTEND_DEFAULT=true
VITE_DASHSCOPE_WATERMARK_DEFAULT=false

# =============================================================================
# GEMINI IMAGE PARAMETERS
# =============================================================================

# Output MIME type options (comma-separated)
VITE_GEMINI_OUTPUT_TYPES=image/png,image/jpeg,image/webp
VITE_GEMINI_OUTPUT_DEFAULT=image/png

# =============================================================================
# SEADREAM IMAGE PARAMETERS
# =============================================================================

# CFG scale configuration
VITE_SEEDREAM_CFG_MIN=1.0
VITE_SEEDREAM_CFG_MAX=20.0
VITE_SEEDREAM_CFG_STEP=0.5

# Steps configuration
VITE_SEEDREAM_STEPS_MIN=1
VITE_SEEDREAM_STEPS_MAX=50

# Sample methods (comma-separated)
VITE_SEEDREAM_SAMPLE_METHODS=default,euler,euler_cfg,heun,heun_cfg,dpm2,dpm2_cfg,dpmpp_2m_sde,dpmpp_2m_sde_cfg,dpmpp_3m_sde,dpmpp_3m_sde_cfg
